# Supabase (Public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional Supabase publishable key (not required for supabase-js)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase (Server Only) - do NOT expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: App settings
NEXT_PUBLIC_APP_NAME=CoffeeOps Executive BI
